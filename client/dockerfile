# Step 1: Use official Node.js image (Alpine for lightweight container)
FROM node:18-alpine

# Step 2: Set working directory inside the container
WORKDIR /app

# Step 3: Copy package.json and package-lock.json (if present)
COPY package.json package-lock.json /app/

# Step 4: Install dependencies (including Vite)
RUN npm install

# Step 5: Copy the rest of the application files into the container
COPY . /app/

# Step 6: Build the app using Vite
RUN npm run build

# Step 7: Expose the port (assuming Vite uses port 3000)
EXPOSE 5173

# Step 8: Start the Vite preview server (for production build)
CMD ["npm", "run", "preview"]
